---
layout: null
permalink: /projects-data.json
---
{
  "themes": [
    {% for t in site.data.research_themes %}
    {
      "id": "{{ t.id }}",
      "title": {{ t.title | jsonify }},
      "short": {{ t.short | jsonify }},
      "tag": {{ t.tag | jsonify }},
      "description": {{ t.description | jsonify }},
      "icon": {{ t.icon | jsonify }},
      "stats": {{ t.stats | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ],
  "projects": [
    {% for p in site.data.projects %}
    {
      "id": "{{ p.id }}",
      "title": {{ p.title | jsonify }},
      "description": {{ p.description | jsonify }},
      "url": {{ p.url | jsonify }},
      "image": {{ p.image | jsonify }},
      "status": "{{ p.status }}",
      "year": {{ p.year | default: "null" }},
      "themes": {{ p.themes | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
